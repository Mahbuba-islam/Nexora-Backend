// =============================================================
// Nexora — AI Shopping Assistant
// =============================================================

model AIConversation {
    id     String             @id @default(uuid()) @db.Uuid
    userId String
    user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

    kind  AIConversationKind @default(SHOPPING_ASSISTANT)
    title String             @db.VarChar(160)

    // Optional context (e.g. last viewed productId, category filter)
    context Json?

    messages AIChatMessage[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
    @@index([kind])
    @@map("ai_conversations")
}

model AIChatMessage {
    id             String         @id @default(uuid()) @db.Uuid
    conversationId String         @db.Uuid
    conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

    role     AIChatMessageRole
    content  String             @db.Text

    // Structured tool/product references rendered by the UI as cards
    toolCalls       Json?
    productRefs     Json? // [{ productId, score, reason }]

    model      String?            @db.VarChar(120)
    provider   String?            @db.VarChar(40)
    tokensUsed Int?
    latencyMs  Int?
    feedback   AIMessageFeedback?

    createdAt DateTime @default(now())

    @@index([conversationId])
    @@map("ai_chat_messages")
}
