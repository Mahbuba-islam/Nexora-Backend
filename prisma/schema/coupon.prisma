// =============================================================
// Nexora — Coupons / Promotions
// =============================================================

model Coupon {
    id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

    code         String             @unique @db.VarChar(40)
    description  String?
    discountType CouponDiscountType
    // For PERCENT: 1-100. For FIXED / FREE_SHIPPING: absolute amount.
    discountValue Decimal @db.Decimal(12, 2)

    // Optional cap for percent discounts (e.g. 20% off up to $50).
    maxDiscount Decimal? @db.Decimal(12, 2)

    // Optional minimum cart subtotal required.
    minAmount Decimal? @db.Decimal(12, 2)

    // Per-user usage cap (null = unlimited)
    perUserLimit Int?

    startsAt  DateTime?
    expiresAt DateTime?
    maxUses   Int?
    usedCount Int       @default(0)

    isActive  Boolean   @default(true)
    isDeleted Boolean   @default(false)
    deletedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([code])
    @@index([isActive])
    @@map("coupons")
}
