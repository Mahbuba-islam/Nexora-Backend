// =============================================================
// Nexora — Refunds / RMA
// =============================================================
//
// A Refund is a customer-initiated request to return an item or
// recover money for a SellerOrder. It moves through:
//
//   REQUESTED → APPROVED → PROCESSING → COMPLETED
//                       ↘ REJECTED
//                       ↘ FAILED
//
// Approval can come from the seller (their sub-order) or admin.
// On COMPLETED we issue a Stripe refund (when the order was paid
// via Stripe) and bump the parent Order's paymentStatus.

model Refund {
    id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

    // Human-friendly code, e.g. "RF-2026-000123"
    refundNumber String @unique @db.VarChar(40)

    // Always tied to a parent Order. SellerOrder is required when
    // the refund only covers one seller's items.
    orderId String @db.Uuid
    order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

    sellerOrderId String?      @db.Uuid
    sellerOrder   SellerOrder? @relation(fields: [sellerOrderId], references: [id], onDelete: SetNull)

    // Convenience for filtering
    sellerId String? @db.Uuid

    // Customer who requested it
    requestedById String
    requestedBy   User   @relation("RefundRequestedBy", fields: [requestedById], references: [id])

    // Approver (seller or admin)
    decidedById String?
    decidedBy   User?   @relation("RefundDecidedBy", fields: [decidedById], references: [id])

    status RefundStatus @default(REQUESTED)
    reason RefundReason
    customerNote String? @db.Text
    decisionNote String? @db.Text

    // Money
    currency       String  @default("USD") @db.VarChar(3)
    requestedAmount Decimal @db.Decimal(12, 2)
    approvedAmount  Decimal? @db.Decimal(12, 2)
    refundedAmount  Decimal @default(0) @db.Decimal(12, 2)

    // Stripe linkage
    stripeRefundId String? @unique
    stripeChargeId String?

    decidedAt   DateTime?
    completedAt DateTime?

    items RefundItem[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([orderId])
    @@index([sellerOrderId])
    @@index([sellerId])
    @@index([requestedById])
    @@index([status])
    @@map("refunds")
}

model RefundItem {
    id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

    refundId String @db.Uuid
    refund   Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)

    orderItemId String    @db.Uuid
    orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

    quantity Int     @default(1)
    amount   Decimal @db.Decimal(12, 2)

    createdAt DateTime @default(now())

    @@index([refundId])
    @@map("refund_items")
}
